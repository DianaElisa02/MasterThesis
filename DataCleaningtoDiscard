def recode_region_name(region_code: pd.Series) -> pd.Series:
    mapping = {
        "ES11": "Galicia",
        "ES12": "Principado de Asturias",
        "ES13": "Cantabria",
        "ES21": "País Vasco",
        "ES22": "Comunidad Foral de Navarra",
        "ES23": "La Rioja",
        "ES24": "Aragón",
        "ES30": "Comunidad de Madrid",
        "ES41": "Castilla y León",
        "ES42": "Castilla-La Mancha",
        "ES43": "Extremadura",
        "ES51": "Cataluña",
        "ES52": "Comunidad Valenciana",
        "ES53": "Illes Balears",
        "ES61": "Andalucía",
        "ES62": "Región de Murcia",
        "ES63": "Ciudad Autónoma de Ceuta",
        "ES64": "Ciudad Autónoma de Melilla",
        "ES70": "Canarias",
        "ESZZ": "Extra-Regio",
    }
    return region_code.map(mapping).astype("string")


def get_age(df: pd.DataFrame, year: int) -> pd.Series:
    if "RB082" in df.columns:
        age = to_num(df["RB082"])
    elif "RB081" in df.columns:
        age = to_num(df["RB081"])
    elif "RB080" in df.columns:
        age = year - to_num(df["RB080"])
    else:
        age = empty_num(df)

    return age.mask((age < 0) | (age > 110), np.nan)


def get_labour_status(df: pd.DataFrame) -> pd.Series:
    # Keep PL031 fallback only if it actually exists in some year/files
    if "PL031" in df.columns:
        v = to_num(df["PL031"])
        out = np.select(
            [
                v.isin([1, 2, 3, 4]),
                v.eq(5),
                v.isin([6, 7, 8, 9, 10, 11]),
            ],
            [
                "working",
                "unemployed",
                "inactive",
            ],
            default=pd.NA
        )
        return pd.Series(out, index=df.index, dtype="string")

    if "PL032" in df.columns:
        v = to_num(df["PL032"])
        out = np.select(
            [
                v.eq(1),
                v.eq(2),
                v.isin([3, 4, 5, 6, 8]),
                v.eq(7),
            ],
            [
                "working",
                "unemployed",
                "inactive",
                "missing",
            ],
            default=pd.NA
        )
        return pd.Series(out, index=df.index, dtype="string")

    return empty_str(df)


