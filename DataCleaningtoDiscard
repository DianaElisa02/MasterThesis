def read_dta_file(path: Path) -> pd.DataFrame:
    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")
    return pd.read_stata(path, convert_categoricals=False)


def make_paths(year: int) -> dict[str, Path]:
    root = BASE_PATH / f"{DATA_PREFIX}{year}"
    return {
        "td": root / f"ECV_Td_{year}" / "STATA" / f"ECV_Td_{year}.dta",
        "th": root / f"ECV_Th_{year}" / "STATA" / f"ECV_Th_{year}.dta",
        "tr": root / f"ECV_Tr_{year}" / "STATA" / f"ECV_Tr_{year}.dta",
        "tp": root / f"ECV_Tp_{year}" / "STATA" / f"ECV_Tp_{year}.dta",
    }


def get_household_cache_path(year: int) -> Path:
    return PROCESSED_DIR / f"ecv_household_{year}.parquet"


def get_person_cache_path(year: int) -> Path:
    return PROCESSED_DIR / f"ecv_person_{year}.parquet"


# =============================================================================
# GENERIC HELPERS
# =============================================================================

def empty_num(df: pd.DataFrame) -> pd.Series:
    return pd.Series(np.nan, index=df.index, dtype="float64")


def empty_str(df: pd.DataFrame) -> pd.Series:
    return pd.Series(pd.NA, index=df.index, dtype="string")


def to_num(s: pd.Series) -> pd.Series:
    return pd.to_numeric(s, errors="coerce")


def to_id(s: pd.Series) -> pd.Series:
    s = s.astype("string").str.strip()
    s = s.str.replace(r"\.0$", "", regex=True)
    return s


def first_existing(df: pd.DataFrame, candidates: list[str]) -> str | None:
    for c in candidates:
        if c in df.columns:
            return c
    return None


def get_series(
    df: pd.DataFrame,
    candidates: list[str],
    *,
    as_id: bool = False,
    numeric: bool = False
) -> pd.Series:
    col = first_existing(df, candidates)
    if col is None:
        if as_id:
            return empty_str(df)
        return empty_num(df) if numeric else empty_str(df)

    s = df[col]
    if as_id:
        return to_id(s)
    if numeric:
        return to_num(s)
    return s.astype("string")


def clean_nonnegative(s: pd.Series) -> pd.Series:
    x = to_num(s)
    return x.mask(x < 0, np.nan)


def clean_total_income(s: pd.Series) -> pd.Series:
    x = to_num(s)
    return x.mask(x < 0, 0)


def assert_unique(df: pd.DataFrame, key: str, name: str) -> None:
    dup = df[key].duplicated(keep=False)
    if dup.any():
        sample = df.loc[dup, key].drop_duplicates().astype("string").head(10).tolist()
        raise ValueError(f"{name}: duplicate {key}. Sample: {sample}")


def safe_left_merge(
    left: pd.DataFrame,
    right: pd.DataFrame,
    on: str,
    validate: str,
    left_name: str,
    right_name: str
) -> pd.DataFrame:
    n0 = len(left)
    out = left.merge(right, on=on, how="left", validate=validate)
    if len(out) != n0:
        raise ValueError(f"Row count changed in merge {left_name} <- {right_name}: {n0} -> {len(out)}")
    return out


