def derive_variables(df: pd.DataFrame, year: int) -> pd.DataFrame:
    out = df.copy()
    out["year"] = year

    out["person_file_available"] = out["person_file_available"].fillna(0.0)
    out["person_composition_observed"] = out["person_composition_observed"].fillna(0.0)
    out["labour_file_available"] = out["labour_file_available"].fillna(0.0)
    out["labour_observed"] = out["labour_observed"].fillna(0.0)
    out["composition_source"] = out["composition_source"].astype("string").fillna("unknown")

    out["composition_data_missing"] = np.where(out["person_composition_observed"].eq(0), 1.0, 0.0)
    out["labour_data_missing"] = np.where(out["labour_observed"].eq(0), 1.0, 0.0)

    out["household_size"] = out["n_persons"].combine_first(out["household_size_raw"])

    out["household_size_source"] = pd.Series(
        np.select(
            [
                out["n_persons"].notna(),
                out["n_persons"].isna() & out["household_size_raw"].notna(),
            ],
            [
                "person_file",
                "household_file",
            ],
            default="missing"
        ),
        index=out.index,
        dtype="string"
    )

    out["children_present"] = np.select(
        [out["n_children"].gt(0), out["n_children"].eq(0)],
        [1.0, 0.0],
        default=np.nan
    )

    out["single_parent_official"] = np.select(
        [out["HX060"].eq(10), out["HX060"].notna()],
        [1.0, 0.0],
        default=np.nan
    )

    out["hh_group_hx060"] = pd.Series(
        np.select(
            [
                out["HX060"].isin([1, 2, 3, 4, 5, 6]),
                out["HX060"].isin([7, 8]),
                out["HX060"].eq(9),
                out["HX060"].eq(10),
                out["HX060"].isin([11, 12, 13]),
                out["HX060"].eq(14),
            ],
            [
                "single_person",
                "two_adults_no_children",
                "other_no_children",
                "single_parent",
                "two_adults_with_children",
                "other_with_children",
            ],
            default=pd.NA
        ),
        index=out.index,
        dtype="string"
    )

    out["hh_group_sim"] = pd.Series(
        np.select(
            [
                (out["n_adults"] == 1) & (out["n_children"] == 0),
                (out["n_adults"] == 1) & (out["n_children"] > 0),
                (out["n_adults"] == 2) & (out["n_children"] == 0),
                (out["n_adults"] == 2) & (out["n_children"] > 0),
                (out["n_adults"] >= 3) & (out["n_children"] == 0),
                (out["n_adults"] >= 3) & (out["n_children"] > 0),
            ],
            [
                "single_adult",
                "one_adult_with_children",
                "two_adults_no_children",
                "two_adults_with_children",
                "threeplus_adults_no_children",
                "threeplus_adults_with_children",
            ],
            default=pd.NA
        ),
        index=out.index,
        dtype="string"
    )

    out["income_before_transfers"] = out["HY022"]
    out["income_before_transfers_monthly"] = out["HY022"] / 12

    out["income_after_transfers"] = out["HY020"]
    out["income_after_transfers_monthly"] = out["HY020"] / 12

    out["capital_income"] = out["HY090"]
    out["capital_income_monthly"] = out["HY090"] / 12
    out["positive_capital_income"] = np.where(
        out["HY090"].notna() & out["HY090"].gt(0), 1.0, 0.0
    )

    out["rental_income_gross"] = out["HY040G"]
    out["rental_income_monthly"] = out["HY040G"] / 12
    out["positive_rental_income"] = np.where(
        out["HY040G"].notna() & out["HY040G"].gt(0), 1.0, 0.0
    )

    out["mortgage_interest_paid"] = out["HY100G"]
    out["positive_mortgage_interest"] = np.where(
        out["HY100G"].notna() & out["HY100G"].gt(0), 1.0, 0.0
    )

    out["wealth_tax_paid_or_property_tax"] = out["HY120G"]
    out["positive_hy120g"] = np.where(
        out["HY120G"].notna() & out["HY120G"].gt(0), 1.0, 0.0
    )

    out["wealth_definition_period"] = pd.Series(
        np.where(out["year"] <= 2020, "pre_2020_definition", "post_2020_definition"),
        index=out.index,
        dtype="string"
    )

    out["any_property_income"] = np.where(
        out["HY040G"].notna() & out["HY040G"].gt(0), 1.0, 0.0
    )

    out["any_asset_income"] = np.where(
        (out["HY040G"].notna() & out["HY040G"].gt(0)) |
        (out["HY090"].notna() & out["HY090"].gt(0)),
        1.0,
        0.0
    )

    out["high_wealth_signal_pre2020"] = np.where(
        (out["year"] <= 2020) &
        (out["HY120G"].notna()) &
        (out["HY120G"].gt(0)),
        1.0,
        0.0
    )

    out["wealth_proxy_strict"] = np.where(
        out["year"] <= 2020,
        np.where(
            (out["HY040G"].notna() & out["HY040G"].gt(0)) |
            (out["HY120G"].notna() & out["HY120G"].gt(0)),
            1.0,
            0.0
        ),
        np.where(
            out["HY040G"].notna() & out["HY040G"].gt(0),
            1.0,
            0.0
        )
    )

    out["wealth_proxy_broad"] = np.where(
        out["year"] <= 2020,
        np.where(
            (out["HY040G"].notna() & out["HY040G"].gt(0)) |
            (out["HY090"].notna() & out["HY090"].gt(0)) |
            (out["HY120G"].notna() & out["HY120G"].gt(0)),
            1.0,
            0.0
        ),
        np.where(
            (out["HY040G"].notna() & out["HY040G"].gt(0)) |
            (out["HY090"].notna() & out["HY090"].gt(0)),
            1.0,
            0.0
        )
    )

    out["resources_total"] = out["income_before_transfers"]
    out["resources_excl_capital"] = np.where(
        out["income_before_transfers"].notna() & out["capital_income"].notna(),
        np.maximum(out["income_before_transfers"] - out["capital_income"], 0),
        np.where(out["income_before_transfers"].notna(), out["income_before_transfers"], np.nan)
    )

    out["tenure_status"] = out["HH021"]
    out["homeowner"] = np.select(
        [out["HH021"].isin([1, 2]), out["HH021"].isin([3, 4, 5])],
        [1.0, 0.0],
        default=np.nan
    )
    out["owner_outright"] = np.select(
        [out["HH021"].eq(1), out["HH021"].isin([2, 3, 4, 5])],
        [1.0, 0.0],
        default=np.nan
    )
    out["owner_with_mortgage"] = np.select(
        [out["HH021"].eq(2), out["HH021"].isin([1, 3, 4, 5])],
        [1.0, 0.0],
        default=np.nan
    )

    out["matdep"] = np.select(
        [out["vhMATDEP"].eq(1), out["vhMATDEP"].eq(0)],
        [1.0, 0.0],
        default=np.nan
    )
    out["poverty"] = np.select(
        [out["vhPobreza"].eq(1), out["vhPobreza"].eq(0)],
        [1.0, 0.0],
        default=np.nan
    )

    out["consumption_units"] = out["HX240"]

    out["any_working"] = out["any_working_18_64"]
    out["any_unemployed"] = out["any_unemployed_18_64"]
    out["n_working"] = out["n_working_18_64"]
    out["n_unemployed"] = out["n_unemployed_18_64"]
    out["n_inactive_working_age"] = out["n_inactive_18_64"]
    out["n_missing_working_age"] = out["n_missing_18_64"]

    out["post"] = np.select(
        [out["year"] >= 2021, out["year"] <= 2019],
        [1.0, 0.0],
        default=np.nan
    )
    out["period"] = pd.Series(
        np.select(
            [out["year"] <= 2019, out["year"] == 2020, out["year"] >= 2021],
            ["pre_2020", "covid_2020", "post_2020"],
            default=pd.NA
        ),
        index=out.index,
        dtype="string"
    )

    out["titular1_age"] = pd.to_numeric(out["titular1_age"], errors="coerce")
    out["titular2_age"] = pd.to_numeric(out["titular2_age"], errors="coerce")

    out["titular1_18plus"] = np.where(out["titular1_age"].ge(18), 1.0, 0.0)
    out["titular1_23plus"] = np.where(out["titular1_age"].ge(23), 1.0, 0.0)
    out["titular1_25plus"] = np.where(out["titular1_age"].ge(25), 1.0, 0.0)

    out["titular2_18plus"] = np.where(out["titular2_age"].ge(18), 1.0, 0.0)
    out["titular2_23plus"] = np.where(out["titular2_age"].ge(23), 1.0, 0.0)
    out["titular2_25plus"] = np.where(out["titular2_age"].ge(25), 1.0, 0.0)

    lab1 = out["titular1_labour_status"]
    lab2 = out["titular2_labour_status"]

    out["titular1_is_unemployed"] = np.nan
    out.loc[lab1.notna(), "titular1_is_unemployed"] = 0.0
    out.loc[lab1.eq("unemployed").fillna(False), "titular1_is_unemployed"] = 1.0

    out["titular1_is_working"] = np.nan
    out.loc[lab1.notna(), "titular1_is_working"] = 0.0
    out.loc[lab1.eq("working").fillna(False), "titular1_is_working"] = 1.0

    out["titular1_is_inactive"] = np.nan
    out.loc[lab1.notna(), "titular1_is_inactive"] = 0.0
    out.loc[lab1.eq("inactive").fillna(False), "titular1_is_inactive"] = 1.0

    out["titular2_is_unemployed"] = np.nan
    out.loc[lab2.notna(), "titular2_is_unemployed"] = 0.0
    out.loc[lab2.eq("unemployed").fillna(False), "titular2_is_unemployed"] = 1.0

    out["titular2_is_working"] = np.nan
    out.loc[lab2.notna(), "titular2_is_working"] = 0.0
    out.loc[lab2.eq("working").fillna(False), "titular2_is_working"] = 1.0

    out["titular2_is_inactive"] = np.nan
    out.loc[lab2.notna(), "titular2_is_inactive"] = 0.0
    out.loc[lab2.eq("inactive").fillna(False), "titular2_is_inactive"] = 1.0

    out["titular_proxy_count"] = (
        out["titular1_found_in_person_file"].fillna(0) +
        out["titular2_found_in_person_file"].fillna(0)
    )

    out["titular_proxy_missing"] = np.where(
        out["titular_proxy_data_available"].fillna(0).eq(0),
        1.0, 0.0
    )

    out["usable_for_rmi_simulation"] = np.where(
        out["region_code"].notna() &
        out["weight_hh"].notna() &
        out["resources_total"].notna() &
        out["person_composition_observed"].eq(1) &
        out["labour_observed"].eq(1) &
        out["titular_proxy_data_available"].eq(1),
        1.0,
        0.0
    )

    assert_unique(out, "HB030", f"final_{year}")
    return out


def process_year(year: int, force_rebuild: bool = False) -> tuple[pd.DataFrame | None, pd.DataFrame | None]:
    hh_cache_path = get_household_cache_path(year)
    person_cache_path = get_person_cache_path(year)

    if hh_cache_path.exists() and person_cache_path.exists() and not force_rebuild:
        logger.info("Loading cached household/person files for %s", year)
        hh = pd.read_parquet(hh_cache_path)
        person = pd.read_parquet(person_cache_path)
        return hh, person

    logger.info("Processing year %s from raw files", year)
    paths = make_paths(year)

    if not paths["td"].exists() or not paths["th"].exists():
        logger.warning("Missing Td or Th for year %s", year)
        return None, None

    td_clean = load_td_clean(paths["td"])
    th_clean = load_th_clean(paths["th"])
    hh_comp, person_data = build_household_composition(paths["tr"], paths["tp"], th_clean, year)
    titular_proxies = build_titular_proxies(th_clean, person_data)

    merged_hh = safe_left_merge(
        th_clean, hh_comp,
        on="HB030", validate="1:1",
        left_name="th_clean", right_name="hh_comp"
    )
    merged_hh = safe_left_merge(
        merged_hh, titular_proxies,
        on="HB030", validate="1:1",
        left_name="merged_hh", right_name="titular_proxies"
    )
    merged_hh = safe_left_merge(
        merged_hh, td_clean,
        on="HB030", validate="1:1",
        left_name="merged_hh", right_name="td_clean"
    )

    logger.info(
        "Year %s | share missing weight_hh = %.4f",
        year,
        float(merged_hh["weight_hh"].isna().mean())
    )

    hh_final = derive_variables(merged_hh, year)
    hh_final.to_parquet(hh_cache_path, index=False)

    person_final = None
    if person_data is not None and not person_data.empty:
        hh_context = hh_final[[
            "HB030", "year", "region_code", "region_name",
            "weight_hh",
            "HX060", "HH021",
            "income_before_transfers", "income_after_transfers",
            "resources_total", "resources_excl_capital",
            "homeowner", "owner_outright", "owner_with_mortgage",
            "poverty", "matdep", "household_size",
            "n_adults", "n_children",
            "wealth_proxy_strict", "wealth_proxy_broad"
        ]].copy()

        person_final = safe_left_merge(
            person_data, hh_context,
            on="HB030", validate="m:1",
            left_name="person_data", right_name="hh_context"
        )
        person_final["year"] = year

        person_final.to_parquet(person_cache_path, index=False)

    logger.info("Saved household/person caches for %s", year)
    return hh_final, person_final


