def weighted_mean(x: pd.Series, w: pd.Series) -> float:
    m = x.notna() & w.notna()
    if not m.any():
        return np.nan
    return float(np.average(x[m], weights=w[m]))


def weighted_share(x: pd.Series, w: pd.Series, value=1) -> float:
    m = x.notna() & w.notna()
    if not m.any():
        return np.nan
    return float(np.average((x[m] == value).astype(float), weights=w[m]))


def make_household_checks(
    df: pd.DataFrame
) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    merge_check = (
        df.groupby("year")
        .agg(
            n_households=("HB030", "size"),
            n_weights=("weight_hh", lambda x: x.notna().sum()),
            n_regions=("region_code", lambda x: x.notna().sum()),
            n_income_resources=("resources_total", lambda x: x.notna().sum()),
            n_labour=("any_working", lambda x: x.notna().sum()),
        )
        .reset_index()
    )

    hh_check = (
        df.groupby("year")
        .apply(lambda g: pd.Series({
            "mean_hhsize_w": weighted_mean(g["household_size"], g["weight_hh"]),
            "pct_homeowner_w": 100 * weighted_share(g["homeowner"], g["weight_hh"], 1.0),
            "pct_poverty_w": 100 * weighted_share(g["poverty"], g["weight_hh"], 1.0),
        }))
        .reset_index()
    )

    composition_check = (
        df.groupby("year")
        .agg(
            n_households=("HB030", "size"),
            n_missing_person_data=("composition_data_missing", lambda x: x.eq(1).sum()),
            pct_missing_person_data=("composition_data_missing", lambda x: x.eq(1).mean() * 100),
            n_missing_labour_data=("labour_data_missing", lambda x: x.eq(1).sum()),
            pct_missing_labour_data=("labour_data_missing", lambda x: x.eq(1).mean() * 100),
            n_household_size_from_household_file=("household_size_source", lambda x: x.eq("household_file").sum()),
            pct_household_size_from_household_file=("household_size_source", lambda x: x.eq("household_file").mean() * 100),
            n_usable_for_rmi=("usable_for_rmi_simulation", lambda x: x.eq(1).sum()),
            pct_usable_for_rmi=("usable_for_rmi_simulation", lambda x: x.eq(1).mean() * 100),
        )
        .reset_index()
    )

    wealth_check = (
        df.groupby("year")
        .apply(lambda g: pd.Series({
            "pct_hy040g_pos_w": 100 * weighted_mean(g["HY040G"].gt(0).astype(float), g["weight_hh"]),
            "pct_hy090_pos_w": 100 * weighted_mean(g["HY090"].gt(0).astype(float), g["weight_hh"]),
            "pct_hy120g_pos_w": 100 * weighted_mean(g["HY120G"].gt(0).astype(float), g["weight_hh"]),
            "pct_wealth_proxy_strict_w": 100 * weighted_share(g["wealth_proxy_strict"], g["weight_hh"], 1.0),
            "pct_wealth_proxy_broad_w": 100 * weighted_share(g["wealth_proxy_broad"], g["weight_hh"], 1.0),
        }))
        .reset_index()
    )

    return merge_check, hh_check, composition_check, wealth_check


