def load_td_clean(path: Path) -> pd.DataFrame:
    td = read_dta_file(path)

    out = pd.DataFrame({
        "HB030": get_series(td, SCHEMA["td"]["household_id"], as_id=True),
        "region_code": get_series(td, SCHEMA["td"]["region_code"], as_id=True),
        "weight_hh": get_series(td, SCHEMA["td"]["weight_hh"], numeric=True),
    })
    out["region_name"] = recode_region_name(out["region_code"])

    assert_unique(out, "HB030", "td_clean")
    return out


def load_th_clean(path: Path) -> pd.DataFrame:
    th = read_dta_file(path)

    capital_col = first_existing(th, SCHEMA["th"]["capital_income"])
    capital_series = clean_nonnegative(th[capital_col]) if capital_col else empty_num(th)

    hhsize_col = first_existing(th, SCHEMA["th"]["household_size_raw"])
    hhsize_series = clean_nonnegative(th[hhsize_col]) if hhsize_col else empty_num(th)

    rental_col = first_existing(th, SCHEMA["th"]["rental_income_gross"])
    rental_series = clean_nonnegative(th[rental_col]) if rental_col else empty_num(th)

    mortgage_col = first_existing(th, SCHEMA["th"]["mortgage_interest_paid"])
    mortgage_series = clean_nonnegative(th[mortgage_col]) if mortgage_col else empty_num(th)

    wealth_tax_col = first_existing(th, SCHEMA["th"]["wealth_tax_paid"])
    wealth_tax_series = clean_nonnegative(th[wealth_tax_col]) if wealth_tax_col else empty_num(th)

    out = pd.DataFrame({
        "HB030": get_series(th, SCHEMA["th"]["household_id"], as_id=True),
        "household_size_raw": hhsize_series,
        "HX060": get_series(th, SCHEMA["th"]["official_hh_type"], numeric=True),
        "HY020": clean_total_income(get_series(th, SCHEMA["th"]["income_after_transfers"], numeric=True)),
        "HY022": clean_total_income(get_series(th, SCHEMA["th"]["income_before_transfers"], numeric=True)),
        "HY090": capital_series,
        "HY040G": rental_series,
        "HY100G": mortgage_series,
        "HY120G": wealth_tax_series,
        "HH021": get_series(th, SCHEMA["th"]["tenure_status"], numeric=True),
        "HX240": clean_nonnegative(get_series(th, SCHEMA["th"]["consumption_units"], numeric=True)),
        "vhPobreza": get_series(th, SCHEMA["th"]["poverty"], numeric=True),
        "vhMATDEP": get_series(th, SCHEMA["th"]["matdep"], numeric=True),
        "HB080": get_series(th, SCHEMA["th"]["responsible_person_1"], as_id=True),
        "HB090": get_series(th, SCHEMA["th"]["responsible_person_2"], as_id=True),
    })

    assert_unique(out, "HB030", "th_clean")
    return out


def load_person_data(tr_path: Path, tp_path: Path, year: int) -> pd.DataFrame:
    tr = read_dta_file(tr_path).copy()

    tr["person_id"] = get_series(tr, SCHEMA["tr"]["person_id"], as_id=True)

    # Dataset-specific rule for Spanish ECV:
    # household ID is embedded in RB030
    tr["HB030"] = tr["person_id"].str[:-2]

    tr["age"] = get_age(tr, year)
    tr["RB050"] = get_series(tr, SCHEMA["tr"]["weight_r"], numeric=True)

    sex_code = get_series(tr, SCHEMA["tr"]["sex"], numeric=True)
    tr["sex"] = pd.Series(
        np.select(
            [sex_code.eq(1), sex_code.eq(2)],
            ["male", "female"],
            default=pd.NA
        ),
        index=tr.index,
        dtype="string"
    )

    tr["partner_id"] = get_series(tr, SCHEMA["tr"]["partner_id"], as_id=True)
    tr["has_partner_id"] = (
        tr["partner_id"].notna() &
        tr["partner_id"].ne("") &
        tr["partner_id"].ne("0")
    )

    tr = tr[[
        "person_id", "HB030", "age", "sex", "has_partner_id", "RB050"
    ]].copy()

    if tp_path.exists():
        tp = read_dta_file(tp_path).copy()
        tp["person_id"] = get_series(tp, SCHEMA["tp"]["person_id"], as_id=True)
        tp["PB040"] = get_series(tp, SCHEMA["tp"]["weight_p"], numeric=True)
        tp["PB060"] = get_series(tp, SCHEMA["tp"]["weight_selected_resp"], numeric=True)
        tp["person_weight_p"] = tp["PB060"].combine_first(tp["PB040"])
        tp["labour_status"] = get_labour_status(tp)

        tp = tp[[
            "person_id", "PB040", "PB060", "person_weight_p", "labour_status"
        ]].copy()

        assert_unique(tp, "person_id", "tp_clean")

        out = safe_left_merge(
            tr, tp,
            on="person_id",
            validate="1:1",
            left_name="tr",
            right_name="tp"
        )
    else:
        out = tr.copy()
        out["PB040"] = np.nan
        out["PB060"] = np.nan
        out["person_weight_p"] = np.nan
        out["labour_status"] = pd.Series(pd.NA, index=out.index, dtype="string")

    out["working_age_18_64"] = out["age"].notna() & out["age"].ge(18) & out["age"].le(64)
    out["labour_status_working_age"] = pd.Series(
        np.where(out["working_age_18_64"], out["labour_status"], pd.NA),
        index=out.index,
        dtype="string"
    )

    out["weight_r_analysis"] = out["RB050"]
    out["weight_p_analysis"] = out["person_weight_p"]
    out["person_weight_preferred"] = out["weight_p_analysis"].combine_first(out["weight_r_analysis"])

    out["person_file_available"] = 1.0
    out["person_composition_observed"] = 1.0
    out["labour_file_available"] = float(tp_path.exists())
    out["labour_observed"] = float(tp_path.exists())
    out["composition_source"] = "person_file"

    assert_unique(out, "person_id", "person_data_final")
    return out


def build_titular_proxies(
    th_clean: pd.DataFrame,
    person_data: pd.DataFrame | None
) -> pd.DataFrame:
    if person_data is None or person_data.empty:
        out = th_clean[["HB030", "HB080", "HB090"]].copy()

        for col in [
            "titular1_person_id", "titular1_age", "titular1_sex", "titular1_labour_status",
            "titular2_person_id", "titular2_age", "titular2_sex", "titular2_labour_status"
        ]:
            out[col] = pd.NA

        out["titular_proxy_data_available"] = 0.0
        out["titular1_found_in_person_file"] = 0.0
        out["titular2_found_in_person_file"] = 0.0
        return out

    person_lookup = person_data[[
        "person_id", "HB030", "age", "sex", "labour_status"
    ]].copy()

    person_lookup = person_lookup.rename(columns={
        "person_id": "lookup_person_id"
    })

    t1 = th_clean[["HB030", "HB080"]].copy()
    t1 = t1.rename(columns={"HB080": "lookup_person_id"})
    t1 = t1.merge(
        person_lookup,
        on="lookup_person_id",
        how="left",
        validate="m:1"
    )
    t1 = t1.rename(columns={
        "lookup_person_id": "titular1_person_id",
        "age": "titular1_age",
        "sex": "titular1_sex",
        "labour_status": "titular1_labour_status",
        "HB030_x": "HB030",
        "HB030_y": "titular1_household_match"
    })

    t2 = th_clean[["HB030", "HB090"]].copy()
    t2 = t2.rename(columns={"HB090": "lookup_person_id"})
    t2 = t2.merge(
        person_lookup,
        on="lookup_person_id",
        how="left",
        validate="m:1"
    )
    t2 = t2.rename(columns={
        "lookup_person_id": "titular2_person_id",
        "age": "titular2_age",
        "sex": "titular2_sex",
        "labour_status": "titular2_labour_status",
        "HB030_x": "HB030",
        "HB030_y": "titular2_household_match"
    })

    out = th_clean[["HB030", "HB080", "HB090"]].copy()
    out = out.merge(
        t1[[
            "HB030", "titular1_person_id", "titular1_age", "titular1_sex",
            "titular1_labour_status"
        ]],
        on="HB030",
        how="left",
        validate="1:1"
    )
    out = out.merge(
        t2[[
            "HB030", "titular2_person_id", "titular2_age", "titular2_sex",
            "titular2_labour_status"
        ]],
        on="HB030",
        how="left",
        validate="1:1"
    )

    out["titular1_found_in_person_file"] = np.where(
        out["titular1_person_id"].notna() & out["titular1_age"].notna(),
        1.0, 0.0
    )
    out["titular2_found_in_person_file"] = np.where(
        out["titular2_person_id"].notna() & out["titular2_age"].notna(),
        1.0, 0.0
    )
    out["titular_proxy_data_available"] = np.where(
        (out["titular1_found_in_person_file"] == 1) |
        (out["titular2_found_in_person_file"] == 1),
        1.0, 0.0
    )

    assert_unique(out, "HB030", "titular_proxies")
    return out


def summarise_household(group: pd.DataFrame) -> pd.Series:
    age = group["age"]
    lsw = group["labour_status_working_age"]
    working_age = group["working_age_18_64"]

    n_adults = int((age >= 18).sum(skipna=True))
    n_children = int((age < 18).sum(skipna=True))
    n_working = int((lsw == "working").sum())
    n_unemployed = int((lsw == "unemployed").sum())
    n_inactive = int((lsw == "inactive").sum())
    n_missing = int(((lsw == "missing") | lsw.isna()).sum())
    n_working_age = int(working_age.sum())

    return pd.Series({
        "n_persons": len(group),
        "n_adults": n_adults,
        "n_children": n_children,
        "n_adults_23plus": int((age >= 23).sum(skipna=True)),
        "n_adults_25plus": int((age >= 25).sum(skipna=True)),
        "one_adult_with_children": float((n_adults == 1) and (n_children > 0)),
        "couple_present": float(group["has_partner_id"].sum(skipna=True) >= 2),
        "n_working_18_64": n_working,
        "n_unemployed_18_64": n_unemployed,
        "n_inactive_18_64": n_inactive,
        "n_missing_18_64": n_missing,
        "any_working_18_64": float(n_working > 0),
        "any_unemployed_18_64": float(n_unemployed > 0),
        "no_working_age_worker": float((n_working_age > 0) and (n_working == 0)),
        "all_working_age_inactive": float((n_working_age > 0) and (n_working == 0) and (n_unemployed == 0) and (n_inactive > 0)),
        "all_working_age_missing": float((n_working_age > 0) and ((n_working + n_unemployed + n_inactive) == 0)),
        "person_file_available": float(group["person_file_available"].iloc[0]),
        "person_composition_observed": float(group["person_composition_observed"].iloc[0]),
        "labour_file_available": float(group["labour_file_available"].iloc[0]),
        "labour_observed": float(group["labour_observed"].iloc[0]),
        "composition_source": group["composition_source"].iloc[0],
    })


def build_household_composition(
    tr_path: Path,
    tp_path: Path,
    th_clean: pd.DataFrame,
    year: int
) -> tuple[pd.DataFrame, pd.DataFrame | None]:
    tr_available = tr_path.exists()
    tp_available = tp_path.exists()

    if not tr_available:
        logger.warning("Missing Tr file for year %s. Household composition will use fallback logic.", year)
        if STRICT_PERSON_DATA:
            raise FileNotFoundError(f"Strict mode enabled: missing Tr file for year {year}")

        out = pd.DataFrame({"HB030": th_clean["HB030"].drop_duplicates()})
        for col in [
            "n_persons", "n_adults", "n_children", "n_adults_23plus", "n_adults_25plus",
            "one_adult_with_children", "couple_present", "n_working_18_64", "n_unemployed_18_64",
            "n_inactive_18_64", "n_missing_18_64", "any_working_18_64", "any_unemployed_18_64",
            "no_working_age_worker", "all_working_age_inactive", "all_working_age_missing"
        ]:
            out[col] = np.nan

        out["person_file_available"] = 0.0
        out["person_composition_observed"] = 0.0
        out["labour_file_available"] = float(tp_available)
        out["labour_observed"] = 0.0
        out["composition_source"] = "fallback_no_tr"

        assert_unique(out, "HB030", "household_composition_fallback")
        return out, None

    if not tp_available:
        logger.warning("Missing Tp file for year %s. Labour variables will be unavailable.", year)

    person_data = load_person_data(tr_path, tp_path, year)

    out = (
        person_data
        .groupby("HB030", dropna=False)
        .apply(summarise_household)
        .reset_index()
    )

    assert_unique(out, "HB030", "household_composition")
    return out, person_data


