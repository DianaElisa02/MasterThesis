year <= 2019 ~ 0,
year == 2020 ~ NA_real_
),
period = case_when(
year <= 2019 ~ "pre_2017_2019",
year == 2020 ~ "covid_2020",
year >= 2021 ~ "post_2021_2025"
)
)
# ---------------------------------------------------------------------------
# 6. Store
# ---------------------------------------------------------------------------
all_data[[as.character(yr)]] <- merged
cat("Year", yr, "processed. Observations:", nrow(merged), "\n")
cat("  - Person file found:", file.exists(tr_path), "\n")
cat("  - Adults derived:", sum(!is.na(merged$adults_final)), "\n")
cat("  - Children derived:", sum(!is.na(merged$children_final)), "\n")
cat("  - Dependents derived:", sum(!is.na(merged$dependents_final)), "\n")
cat("  - Capital income available:", sum(!is.na(merged$capital_income)), "\n")
cat("  - Homeownership available:", sum(!is.na(merged$homeowner)), "\n")
cat("  - Employment info available:", sum(!is.na(merged$any_employed)), "\n")
}
library(tidyverse)
library(haven)
# =============================================================================
# ECV DATA PREPARATION FOR IMV / REGIONAL RMI THESIS
# Years: 2017-2025
# Merge:
#   Td = household register (region, weights)
#   Th = household detailed data (income, tenure, outcomes)
#   Tr = person file (age, composition, labour status)
#
# Main goal:
#   Build a clean household-level dataset for regional RMI simulation.
#
# Baseline simulation variables:
#   - region
#   - household size / composition
#   - age structure
#   - total disposable income
#   - capital income
#   - housing tenure
#
# Optional descriptive / robustness variables:
#   - labour-market attachment (from PL032)
# =============================================================================
# -----------------------------------------------------------------------------
# Paths and years
# -----------------------------------------------------------------------------
base_path <- "C:/Users/diana/Documents/Master-Policy Economics/Thesis/datos_"
years <- 2017:2025
# -----------------------------------------------------------------------------
# Helper: pick first variable name that exists
# -----------------------------------------------------------------------------
pick_first_existing <- function(data, candidates) {
existing <- candidates[candidates %in% names(data)]
if (length(existing) == 0) return(rep(NA_real_, nrow(data)))
x <- haven::zap_labels(data[[existing[1]]])
suppressWarnings(as.numeric(x))
}
get_person_id <- function(data) {
id_candidates <- c("RB030", "PB030", "DB030")
existing <- id_candidates[id_candidates %in% names(data)]
if (length(existing) == 0) {
stop("No person ID variable found. Checked: ", paste(id_candidates, collapse = ", "))
}
as.character(haven::zap_labels(data[[existing[1]]]))
}
# -----------------------------------------------------------------------------
# Helper: get age from available variables
# Priority:
#   RB082 = age at interview
#   RB081 = age at end of previous year
#   RB080 = birth year
# -----------------------------------------------------------------------------
get_age <- function(data, survey_year) {
age_raw <- if ("RB082" %in% names(data)) {
suppressWarnings(as.numeric(haven::zap_labels(data$RB082)))
} else if ("RB081" %in% names(data)) {
suppressWarnings(as.numeric(haven::zap_labels(data$RB081)))
} else if ("RB080" %in% names(data)) {
survey_year - suppressWarnings(as.numeric(haven::zap_labels(data$RB080)))
} else {
rep(NA_real_, nrow(data))
}
age_clean <- ifelse(age_raw < 0 | age_raw > 110, NA_real_, age_raw)
age_clean
}
# -----------------------------------------------------------------------------
# Helper: clean numeric variables
# Negative values are treated as missing
# -----------------------------------------------------------------------------
clean_num <- function(x) {
x <- haven::zap_labels(x)
x <- suppressWarnings(as.numeric(x))
x[x < 0] <- NA_real_
x
}
# -----------------------------------------------------------------------------
# Helper: labour status from PL032
#
# PL032 = self-defined activity status:
# 1 Working
# 2 Unemployed
# 3 Retired
# 4 Permanently disabled
# 5 Student
# 6 Homemaker / carer
# 7 No individual questionnaire
# 8 Other inactivity
# -----------------------------------------------------------------------------
get_labour_status <- function(data) {
if (!"PL032" %in% names(data)) {
return(rep(NA_character_, nrow(data)))
}
v <- haven::zap_labels(data$PL032)
v <- suppressWarnings(as.numeric(v))
case_when(
v == 1 ~ "employed",
v == 2 ~ "unemployed",
v %in% c(3, 4, 5, 6, 8) ~ "inactive",
v == 7 ~ NA_character_,
TRUE ~ NA_character_
)
}
# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
all_data <- list()
# =============================================================================
# LOOP OVER YEARS
# =============================================================================
for (yr in years) {
cat("\n", paste(rep("=", 60), collapse = ""))
cat("\nProcessing year:", yr)
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
# ---------------------------------------------------------------------------
# 1. Td: Household register
# ---------------------------------------------------------------------------
td_path <- paste0(base_path, yr, "/ECV_Td_", yr, "/STATA/ECV_Td_", yr, ".dta")
cat("Td path:", td_path, "\n")
if (!file.exists(td_path)) {
warning("Td file not found for year ", yr)
next
}
td <- read_dta(td_path)
td_clean <- td %>%
transmute(
DB030 = as.character(DB030),
region = as.character(DB040),
weight = suppressWarnings(as.numeric(haven::zap_labels(DB090))),
urban = suppressWarnings(as.numeric(haven::zap_labels(DB100)))
)
# ---------------------------------------------------------------------------
# 2. Th: Household detailed file
# ---------------------------------------------------------------------------
th_path <- paste0(base_path, yr, "/ECV_Th_", yr, "/STATA/ECV_Th_", yr, ".dta")
cat("Th path:", th_path, "\n")
if (!file.exists(th_path)) {
warning("Th file not found for year ", yr)
next
}
th <- read_dta(th_path)
th_clean <- th %>%
mutate(
HB030 = as.character(HB030),
HX060 = suppressWarnings(as.numeric(na_if(as.character(haven::zap_labels(HX060)), ""))),
household_size_raw = pick_first_existing(., c("HB120", "HX040")),
HY020 = clean_num(HY020),
HY090 = clean_num(pick_first_existing(., c("HY090", "HY090N", "HY090G"))),
HY040 = clean_num(pick_first_existing(., c("HY040", "HY040N", "HY040G"))),
HY050 = clean_num(pick_first_existing(., c("HY050", "HY050N", "HY050G"))),
HH021 = suppressWarnings(as.numeric(pick_first_existing(., c("HH021")))),
HD225 = clean_num(pick_first_existing(., c("HD225"))),
vhMATDEP = clean_num(pick_first_existing(., c("vhMATDEP"))),
vhPobreza = clean_num(pick_first_existing(., c("vhPobreza"))),
HX240 = clean_num(pick_first_existing(., c("HX240"))),
HI012 = clean_num(pick_first_existing(., c("HI012"))),
HY150_1 = clean_num(pick_first_existing(., c("HY150_1"))),
HY150_2 = clean_num(pick_first_existing(., c("HY150_2"))),
HY150_3 = clean_num(pick_first_existing(., c("HY150_3"))),
HY150_4 = clean_num(pick_first_existing(., c("HY150_4")))
) %>%
select(any_of(c(
"HB030",
"HY020", "HY090", "HY040", "HY050",
"HH021", "HD225",
"vhMATDEP", "vhPobreza",
"HX060", "HX240",
"household_size_raw",
"HI012", "HY150_1", "HY150_2", "HY150_3", "HY150_4"
)))
# ---------------------------------------------------------------------------
# 3. Tr + Tp: Person files
# ---------------------------------------------------------------------------
tr_path <- paste0(base_path, yr, "/ECV_Tr_", yr, "/STATA/ECV_Tr_", yr, ".dta")
tp_path <- paste0(base_path, yr, "/ECV_Tp_", yr, "/STATA/ECV_Tp_", yr, ".dta")
cat("Tr path:", tr_path, "\n")
cat("Tp path:", tp_path, "\n")
if (!file.exists(tr_path)) {
warning("Tr file not found for year ", yr, ". Using Th-derived composition only.")
household_composition <- tibble(
HB030 = unique(th_clean$HB030),
n_persons = NA_real_,
n_adults = NA_real_,
n_children = NA_real_,
n_adults_23plus = NA_real_,
n_adults_25plus = NA_real_,
n_dependents = NA_real_,
single_parent_derived = NA_real_,
couple_present = NA_real_,
hh_head_age = NA_real_,
hh_head_sex = NA_character_,
n_employed = NA_real_,
n_unemployed = NA_real_,
n_inactive = NA_real_,
any_employed = NA_real_,
any_unemployed = NA_real_
)
} else {
tr <- read_dta(tr_path) %>%
mutate(
person_id = get_person_id(.),
HB030 = substr(person_id, 1, nchar(person_id) - 2),
age = get_age(., survey_year = yr),
sex = case_when(
as.character(haven::zap_labels(RB090)) == "1" ~ "male",
as.character(haven::zap_labels(RB090)) == "2" ~ "female",
TRUE ~ NA_character_
),
partner_id = if ("RB240" %in% names(.)) as.character(haven::zap_labels(RB240)) else NA_character_,
has_partner_id = !is.na(partner_id) & partner_id != "" & partner_id != "0"
) %>%
select(person_id, HB030, age, sex, partner_id, has_partner_id)
if (file.exists(tp_path)) {
tp <- read_dta(tp_path) %>%
mutate(
person_id = get_person_id(.),
labour_status = get_labour_status(.)
) %>%
select(person_id, labour_status)
person_data <- tr %>%
left_join(tp, by = "person_id")
cat("  Raw PL032 distribution from Tp:\n")
if ("PL032" %in% names(read_dta(tp_path))) {
tp_raw <- read_dta(tp_path)
print(table(as.numeric(haven::zap_labels(tp_raw$PL032)), useNA = "ifany"))
}
cat("  Labour status distribution after merge:\n")
print(table(person_data$labour_status, useNA = "ifany"))
} else {
warning("Tp file not found for year ", yr, ". Labour status unavailable.")
person_data <- tr %>%
mutate(labour_status = NA_character_)
}
household_composition <- person_data %>%
group_by(HB030) %>%
summarise(
n_persons = n(),
n_adults = sum(age >= 18, na.rm = TRUE),
n_children = sum(age < 18, na.rm = TRUE),
n_adults_23plus = sum(age >= 23, na.rm = TRUE),
n_adults_25plus = sum(age >= 25, na.rm = TRUE),
n_dependents = sum(age < 18, na.rm = TRUE),
single_parent_derived = as.numeric(
sum(age >= 18, na.rm = TRUE) == 1 &
sum(age < 18, na.rm = TRUE) > 0
),
couple_present = as.numeric(sum(has_partner_id, na.rm = TRUE) >= 2),
n_employed = sum(labour_status == "employed", na.rm = TRUE),
n_unemployed = sum(labour_status == "unemployed", na.rm = TRUE),
n_inactive = sum(labour_status == "inactive", na.rm = TRUE),
any_employed = as.numeric(n_employed > 0),
any_unemployed = as.numeric(n_unemployed > 0),
hh_head_age = NA_real_,
hh_head_sex = NA_character_,
.groups = "drop"
)
cat("  Household employment indicator distribution:\n")
print(table(household_composition$any_employed, useNA = "ifany"))
print(table(household_composition$any_unemployed, useNA = "ifany"))
}
# ---------------------------------------------------------------------------
# 4. Merge Th + composition + Td
# ---------------------------------------------------------------------------
merged <- th_clean %>%
left_join(household_composition, by = "HB030") %>%
left_join(td_clean, by = c("HB030" = "DB030")) %>%
mutate(year = yr)
# ---------------------------------------------------------------------------
# 5. Derived variables
# ---------------------------------------------------------------------------
merged <- merged %>%
mutate(
matdep = case_when(
vhMATDEP == 1 ~ 1,
vhMATDEP == 0 ~ 0,
TRUE ~ NA_real_
),
poverty = case_when(
vhPobreza == 1 ~ 1,
vhPobreza == 0 ~ 0,
TRUE ~ NA_real_
),
adults_final = n_adults,
children_final = n_children,
dependents_final = n_dependents,
adults_23plus_final = n_adults_23plus,
adults_25plus_final = n_adults_25plus,
household_size = if_else(
!is.na(household_size_raw),
household_size_raw,
adults_final + children_final
),
children_present = case_when(
!is.na(children_final) ~ as.numeric(children_final > 0),
HX060 %in% 10:14 ~ 1,
!is.na(HX060) ~ 0,
TRUE ~ NA_real_
),
single_parent = case_when(
!is.na(single_parent_derived) ~ single_parent_derived,
HX060 == 10 ~ 1,
!is.na(HX060) ~ 0,
TRUE ~ NA_real_
),
single_person = case_when(
!is.na(adults_final) & !is.na(children_final) ~
as.numeric(adults_final == 1 & children_final == 0),
HX060 %in% 1:6 ~ 1,
!is.na(HX060) ~ 0,
TRUE ~ NA_real_
),
couple_present_final = if_else(is.na(couple_present), 0, couple_present),
hh_group_hx060 = case_when(
HX060 %in% 1:6 ~ "single_person",
HX060 %in% c(7, 8) ~ "two_adults_no_children",
HX060 == 9 ~ "other_no_children",
HX060 == 10 ~ "single_parent",
HX060 %in% 11:13 ~ "two_adults_with_children",
HX060 == 14 ~ "other_with_children",
TRUE ~ NA_character_
),
hh_group_person = case_when(
!is.na(adults_final) & !is.na(children_final) &
adults_final == 1 & children_final == 0 ~ "single_person",
!is.na(adults_final) & !is.na(children_final) &
adults_final == 1 & children_final > 0 ~ "single_parent",
!is.na(adults_final) & !is.na(children_final) &
adults_final == 2 & children_final == 0 ~ "two_adults_no_children",
!is.na(adults_final) & !is.na(children_final) &
adults_final == 2 & children_final > 0 ~ "two_adults_with_children",
!is.na(adults_final) & !is.na(children_final) &
adults_final > 2 & children_final == 0 ~ "multi_adult_no_children",
!is.na(adults_final) & !is.na(children_final) &
adults_final > 2 & children_final > 0 ~ "multi_adult_with_children",
TRUE ~ NA_character_
),
hh_group = hh_group_hx060,
income_net = if_else(HY020 < 0, 0, HY020, missing = NA_real_),
income_monthly = income_net / 12,
log_income = log(income_net + 1),
capital_income = if_else(HY090 < 0, 0, HY090, missing = NA_real_),
capital_income_monthly = capital_income / 12,
transfers_income = if_else(HY040 < 0, 0, HY040, missing = NA_real_),
transfers_income_monthly = transfers_income / 12,
pension_income = if_else(HY050 < 0, 0, HY050, missing = NA_real_),
pension_income_monthly = pension_income / 12,
resources_total = income_net,
resources_total_monthly = resources_total / 12,
resources_excl_capital = case_when(
!is.na(income_net) & !is.na(capital_income) ~ pmax(income_net - capital_income, 0),
!is.na(income_net) ~ income_net,
TRUE ~ NA_real_
),
resources_excl_capital_monthly = resources_excl_capital / 12,
positive_capital_income = case_when(
!is.na(capital_income) ~ as.numeric(capital_income > 0),
TRUE ~ NA_real_
),
tenure_status = HH021,
homeowner = case_when(
HH021 %in% c(1, 2) ~ 1,
HH021 %in% c(3, 4, 5) ~ 0,
TRUE ~ NA_real_
),
owner_outright = case_when(
HH021 == 1 ~ 1,
HH021 %in% c(2, 3, 4, 5) ~ 0,
TRUE ~ NA_real_
),
owner_with_mortgage = case_when(
HH021 == 2 ~ 1,
HH021 %in% c(1, 3, 4, 5) ~ 0,
TRUE ~ NA_real_
),
homeowner_and_capital_income = case_when(
!is.na(homeowner) & !is.na(positive_capital_income) ~
as.numeric(homeowner == 1 & positive_capital_income == 1),
TRUE ~ NA_real_
),
outright_owner_and_capital_income = case_when(
!is.na(owner_outright) & !is.na(positive_capital_income) ~
as.numeric(owner_outright == 1 & positive_capital_income == 1),
TRUE ~ NA_real_
),
any_employed = any_employed,
any_unemployed = any_unemployed,
post = case_when(
year >= 2021 ~ 1,
year <= 2019 ~ 0,
year == 2020 ~ NA_real_
),
period = case_when(
year <= 2019 ~ "pre_2017_2019",
year == 2020 ~ "covid_2020",
year >= 2021 ~ "post_2021_2025"
)
)
# ---------------------------------------------------------------------------
# 6. Store
# ---------------------------------------------------------------------------
all_data[[as.character(yr)]] <- merged
cat("Year", yr, "processed. Observations:", nrow(merged), "\n")
cat("  - Person file found:", file.exists(tr_path), "\n")
cat("  - Adults derived:", sum(!is.na(merged$adults_final)), "\n")
cat("  - Children derived:", sum(!is.na(merged$children_final)), "\n")
cat("  - Dependents derived:", sum(!is.na(merged$dependents_final)), "\n")
cat("  - Capital income available:", sum(!is.na(merged$capital_income)), "\n")
cat("  - Homeownership available:", sum(!is.na(merged$homeowner)), "\n")
cat("  - Employment info available:", sum(!is.na(merged$any_employed)), "\n")
}
# =============================================================================
# COMBINE ALL YEARS
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""))
cat("\nCOMBINING ALL YEARS")
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
ecv_final <- bind_rows(all_data)
cat("\nFinal dataset dimensions:", nrow(ecv_final), "rows,", ncol(ecv_final), "columns\n")
cat("\nYears present:\n")
print(table(ecv_final$year, useNA = "ifany"))
# =============================================================================
# CHECK MERGE QUALITY
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""))
cat("\nCHECKING MERGE QUALITY")
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
merge_check <- ecv_final %>%
group_by(year) %>%
summarise(
n_obs = n(),
n_region = sum(!is.na(region)),
n_weight = sum(!is.na(weight)),
n_matdep = sum(!is.na(matdep)),
n_poverty = sum(!is.na(poverty)),
n_income = sum(!is.na(income_net)),
n_capital_income = sum(!is.na(capital_income)),
n_homeowner = sum(!is.na(homeowner)),
n_adults = sum(!is.na(adults_final)),
n_children = sum(!is.na(children_final)),
n_dependents = sum(!is.na(dependents_final)),
n_emp_info = sum(!is.na(any_employed)),
.groups = "drop"
)
print(merge_check)
# =============================================================================
# CHECK HOUSEHOLD COMPOSITION
# =============================================================================
cat("\n", paste(rep("=", 60), collapse = ""))
cat("\nCHECKING HOUSEHOLD COMPOSITION")
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
hh_check <- ecv_final %>%
group_by(year) %>%
summarise(
n_obs = n(),
mean_adults = mean(adults_final, na.rm = TRUE),
mean_children = mean(children_final, na.rm = TRUE),
mean_dependents = mean(dependents_final, na.rm = TRUE),
mean_hhsize = mean(household_size, na.rm = TRUE),
pct_single_parent = mean(single_parent == 1, na.rm = TRUE) * 100,
pct_couple = mean(couple_present_final == 1, na.rm = TRUE) * 100,
pct_homeowner = mean(homeowner == 1, na.rm = TRUE) * 100,
pct_positive_capital = mean(positive_capital_income == 1, na.rm = TRUE) * 100,
pct_any_employed = mean(any_employed == 1, na.rm = TRUE) * 100,
pct_any_unemployed = mean(any_unemployed == 1, na.rm = TRUE) * 100,
.groups = "drop"
)
print(hh_check)
cat("\nDistribution of hh_group (official HX060):\n")
print(table(ecv_final$hh_group, useNA = "ifany"))
cat("\nDistribution of hh_group_hx060:\n")
print(table(ecv_final$hh_group_hx060, useNA = "ifany"))
cat("\nDistribution of hh_group_person:\n")
print(table(ecv_final$hh_group_person, useNA = "ifany"))
cat("\nHomeownership distribution:\n")
print(table(ecv_final$homeowner, useNA = "ifany"))
cat("\nPositive capital income distribution:\n")
print(table(ecv_final$positive_capital_income, useNA = "ifany"))
cat("\nEmployment distribution (any_employed):\n")
print(table(ecv_final$any_employed, useNA = "ifany"))
cat("\nEmployment distribution (any_unemployed):\n")
print(table(ecv_final$any_unemployed, useNA = "ifany"))
# =============================================================================
# SAVE DATASET
# =============================================================================
output_path <- "C:/Users/diana/Documents/Master-Policy Economics/Thesis/ecv_2017_2025_clean.rds"
saveRDS(ecv_final, file = output_path)
cat("\n", paste(rep("=", 60), collapse = ""))
cat("\nDATA PREPARATION COMPLETE!")
cat("\nFile saved to:", output_path)
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
