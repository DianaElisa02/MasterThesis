def make_year_summary(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for year, g in df.groupby("year"):
        simulated_total = g.loc[g["rmi_positive_entitlement"] == 1, "weight_hh"].sum()

        coverage_year = g[["nuts_code", "titulares"]].drop_duplicates().copy()

        if coverage_year["nuts_code"].duplicated().any():
            dup_codes = coverage_year.loc[coverage_year["nuts_code"].duplicated(), "nuts_code"].tolist()
            raise ValueError(f"Duplicate nuts_code values in year coverage summary for {year}: {dup_codes}")

        titulares_year = coverage_year["titulares"].sum()

        rows.append({
            "year": year,
            "weighted_total_simulated_households": simulated_total,
            "observed_titulares": titulares_year,
            "absolute_gap_sim_minus_titulares": simulated_total - titulares_year,
            "pct_gap_vs_titulares": safe_pct_gap(simulated_total, titulares_year),
        })

    return pd.DataFrame(rows).sort_values("year")


def make_region_summary(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (nuts_code, year), g in df.groupby(["nuts_code", "year"]):
        simulated_total = g.loc[g["rmi_positive_entitlement"] == 1, "weight_hh"].sum()

        region_names = g["region_name_policy"].dropna().unique()
        if len(region_names) != 1:
            raise ValueError(
                f"Expected exactly one region_name_policy for nuts_code={nuts_code}, year={year}, "
                f"found {region_names.tolist()}"
            )
        region = region_names[0]

        titulares_values = g["titulares"].dropna().unique()
        if len(titulares_values) != 1:
            raise ValueError(
                f"Expected exactly one titulares value for nuts_code={nuts_code}, year={year}, "
                f"found {titulares_values.tolist()}"
            )

        titulares_region_year = float(titulares_values[0])

        rows.append({
            "nuts_code": nuts_code,
            "region_name_policy": region,
            "year": year,
            "weighted_total_simulated_households": simulated_total,
            "observed_titulares": titulares_region_year,
            "absolute_gap_sim_minus_titulares": simulated_total - titulares_region_year,
            "pct_gap_vs_titulares": safe_pct_gap(simulated_total, titulares_region_year),
        })

    return pd.DataFrame(rows).sort_values(["year", "region_name_policy"])

def make_threshold_diagnostic(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (nuts_code, year), g in df.groupby(["nuts_code", "year"]):
        resources = g["threshold_resources_monthly"]
        guarantee = g["rmi_guaranteed_amount_monthly"]

        region_names = g["region_name_policy"].dropna().unique()
        if len(region_names) != 1:
            raise ValueError(
                f"Expected exactly one region_name_policy for nuts_code={nuts_code}, year={year}, "
                f"found {region_names.tolist()}"
            )
        region = region_names[0]

        weighted_income_eligible = g.loc[g["rmi_income_eligible"] == 1, "weight_hh"].sum()
        weighted_amount_available = g.loc[g["rmi_guaranteed_amount_monthly"].notna(), "weight_hh"].sum()

        rows.append({
            "nuts_code": nuts_code,
            "region_name_policy": region,
            "year": year,
            "weighted_mean_threshold_resources": weighted_mean(resources, g["weight_hh"]),
            "weighted_mean_guaranteed_amount": weighted_mean(guarantee, g["weight_hh"]),
            "weighted_total_income_eligible": weighted_income_eligible,
            "weighted_share_income_eligible_among_amount_observed":
            weighted_income_eligible / weighted_amount_available if weighted_amount_available > 0 else np.nan,
        })

    return pd.DataFrame(rows).sort_values(["year", "region_name_policy"])


def make_region_diagnostic_table(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (nuts_code, year), g in df.groupby(["nuts_code", "year"]):
        total = g["weight_hh"].sum()

        region_names = g["region_name_policy"].dropna().unique()
        if len(region_names) != 1:
            raise ValueError(
                f"Expected exactly one region_name_policy for nuts_code={nuts_code}, year={year}, "
                f"found {region_names.tolist()}"
            )
        region = region_names[0]

        titulares_values = g["titulares"].dropna().unique()
        if len(titulares_values) != 1:
            raise ValueError(
                f"Expected exactly one titulares value for nuts_code={nuts_code}, year={year}, "
                f"found {titulares_values.tolist()}"
            )
        titulares = float(titulares_values[0])

        after_wealth = g.loc[g["rmi_wealth_eligible"] == 1, "weight_hh"].sum()
        after_labour = g.loc[g["rmi_labour_eligible"] == 1, "weight_hh"].sum()
        after_income = g.loc[g["rmi_income_eligible"] == 1, "weight_hh"].sum()
        final_sim = g.loc[g["rmi_sim_eligible"] == 1, "weight_hh"].sum()

        rows.append({
            "nuts_code": nuts_code,
            "region_name_policy": region,
            "year": year,
            "observed_titulares": titulares,
            "simulated_households": final_sim,
            "pct_gap_vs_titulares": safe_pct_gap(final_sim, titulares),

            "share_after_wealth_rule": after_wealth / total if total > 0 else np.nan,
            "share_after_labour_rule": after_labour / total if total > 0 else np.nan,
            "share_after_income_test": after_income / total if total > 0 else np.nan,
            "share_final_simulated": final_sim / total if total > 0 else np.nan,

            "labour_over_wealth_ratio": after_labour / after_wealth if after_wealth > 0 else np.nan,
            "income_over_labour_ratio": after_income / after_labour if after_labour > 0 else np.nan,
            "final_over_income_ratio": final_sim / after_income if after_income > 0 else np.nan,
        })

    return pd.DataFrame(rows).sort_values(["year", "pct_gap_vs_titulares"], ascending=[True, False])


def make_eligibility_funnel(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (nuts_code, year), g in df.groupby(["nuts_code", "year"]):
        w = g["weight_hh"]
        total = w.sum()

        region_names = g["region_name_policy"].dropna().unique()
        if len(region_names) != 1:
            raise ValueError(
                f"Expected exactly one region_name_policy for nuts_code={nuts_code}, year={year}, "
                f"found {region_names.tolist()}"
            )
        region = region_names[0]

        region_included = g.loc[g["baseline_main_included"] == True, "weight_hh"].sum()
        amount_available = g.loc[g["rmi_amount_rule_available"] == 1, "weight_hh"].sum()
        age_eligible = g.loc[g["rmi_age_eligible"] == 1, "weight_hh"].sum()
        wealth_eligible = g.loc[g["rmi_wealth_eligible"] == 1, "weight_hh"].sum()
        hhtype_eligible = g.loc[g["rmi_hhtype_eligible"] == 1, "weight_hh"].sum()
        threeplus_ok = g.loc[g["rmi_threeplus_adults_allowed"] == 1, "weight_hh"].sum()
        labour_eligible = g.loc[g["rmi_labour_eligible"] == 1, "weight_hh"].sum()
        pfilter = g.loc[g["passes_percentile_filter"] == 1, "weight_hh"].sum()
        income_eligible = g.loc[g["rmi_income_eligible"] == 1, "weight_hh"].sum()
        simulated = g.loc[g["rmi_sim_eligible"] == 1, "weight_hh"].sum()

        rows.append({
            "nuts_code": nuts_code,
            "region_name_policy": region,
            "year": year,
            "total_households": total,
            "after_region_included": region_included,
            "after_amount_available": amount_available,
            "after_age_rule": age_eligible,
            "after_wealth_rule": wealth_eligible,
            "after_hh_type_rule": hhtype_eligible,
            "after_threeplus_rule": threeplus_ok,
            "after_labour_rule": labour_eligible,
            "after_percentile_filter": pfilter,
            "after_income_test": income_eligible,
            "final_simulated": simulated,
            "share_after_pfilter": pfilter / total if total > 0 else np.nan,
            "share_after_income": income_eligible / total if total > 0 else np.nan,
            "share_final": simulated / total if total > 0 else np.nan,
        })

    return pd.DataFrame(rows).sort_values(["year", "region_name_policy"])

def reorder_columns(df: pd.DataFrame) -> pd.DataFrame:
    preferred = [
        "household_id",
        "year",
        "nuts_code",
        "region_name",
        "region",
        "program_name",
        "weight_hh",
        "household_size",
        "hh_size_rule",
        "pfilter_resources_monthly",
        "threshold_resources_monthly",
        "percentile_cutoff_monthly",
        "passes_percentile_filter",
        "baseline_main_included",
        "baseline_amount_method",
        "baseline_age_threshold",
        "rmi_guaranteed_amount_monthly",
        "rmi_amount_assignment_type",
        "rmi_age_eligible",
        "rmi_age_rule_source",
        "rmi_wealth_eligible",
        "rmi_hhtype_eligible",
        "rmi_threeplus_adults_allowed",
        "labour_income_hh_monthly",
        "any_positive_labour_income",
        "rmi_labour_eligible",
        "rmi_labour_rule_source",
        "rmi_income_eligible",
        "rmi_income_gap_entitlement_monthly",
        "rmi_sim_eligible",
        "rmi_simulated_benefit_monthly",
        "rmi_positive_entitlement",
        "rmi_exclusion_reason",
    ]
    existing = [c for c in preferred if c in df.columns]
    remaining = [c for c in df.columns if c not in existing]
    return df[existing + remaining]


def make_labour_rule_diagnostic(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (nuts_code, year), g in df.groupby(["nuts_code", "year"]):
        total = g["weight_hh"].sum()

        region_names = g["region_name_policy"].dropna().unique()
        if len(region_names) != 1:
            raise ValueError(
                f"Expected exactly one region_name_policy for nuts_code={nuts_code}, year={year}, "
                f"found {region_names.tolist()}"
            )
        region = region_names[0]

        labour_ok = g.loc[g["rmi_labour_eligible"] == 1, "weight_hh"].sum()

        source_income = g.loc[g["rmi_labour_rule_source"] == "labour_income_rule", "weight_hh"].sum()
        source_backup = g.loc[
            g["rmi_labour_rule_source"].isin(["labour_status_backup", "nonworking_household_backup"]),
            "weight_hh"
        ].sum()
        source_fail = g.loc[g["rmi_labour_rule_source"] == "fails_labour_rule", "weight_hh"].sum()

        rows.append({
            "nuts_code": nuts_code,
            "region_name_policy": region,
            "year": year,
            "total_households": total,
            "labour_eligible": labour_ok,
            "share_labour_eligible": labour_ok / total if total > 0 else np.nan,
            "share_labour_income_rule": source_income / total if total > 0 else np.nan,
            "share_labour_backup_rule": source_backup / total if total > 0 else np.nan,
            "share_fails_labour_rule": source_fail / total if total > 0 else np.nan,
        })

    return pd.DataFrame(rows).sort_values(["year", "region_name_policy"])


