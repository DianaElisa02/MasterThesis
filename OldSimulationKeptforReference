def merge_inputs(
    hh: pd.DataFrame,
    rules: pd.DataFrame,
    schedule: pd.DataFrame,
    coverage: pd.DataFrame
) -> pd.DataFrame:
    out = hh.merge(
        rules,
        on=["nuts_code", "year"],
        how="left",
        validate="m:1"
    )

    out = out.merge(
        schedule,
        on=["nuts_code", "year", "hh_size_rule"],
        how="left",
        validate="m:1",
        suffixes=("", "_sched")
    )

    out = out.merge(
        coverage,
        on=["nuts_code", "year"],
        how="left",
        validate="m:1",
        suffixes=("", "_cov")
    )

    return out


